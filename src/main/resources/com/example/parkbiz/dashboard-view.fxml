<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.parkbiz.DashboardController">
    <children>
        <!-- SIDEBAR -->
        <VBox prefWidth="220.0" spacing="15.0" style="-fx-border-color: #ff8c00; -fx-border-width: 0 2 0 0;" AnchorPane.bottomAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Text fill="#ff8c00" strokeType="OUTSIDE" strokeWidth="0.0" text="[ MENU ]">
                    <font><Font name="Monospaced Bold" size="18.0" /></font>
                </Text>
                <Button maxWidth="Infinity" style="-fx-background-color: #ff8c00; -fx-text-fill: black; -fx-font-family: 'Monospaced'; -fx-font-weight: bold;" text="VIEW SLOTS" />
                <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #ff8c00; -fx-border-color: #ff8c00; -fx-font-family: 'Monospaced';" text="MY RESERVATION" />
                <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #ff8c00; -fx-border-color: #ff8c00; -fx-font-family: 'Monospaced';" text="PAYMENT" />
                <VBox VBox.vgrow="ALWAYS" />
                <Button onAction="#handleLogout" maxWidth="Infinity" style="-fx-background-color: #440000; -fx-text-fill: #ff8c00; -fx-border-color: #ff8c00; -fx-font-family: 'Monospaced';" text="DISCONNECT" />
            </children>
        </VBox>

        <!-- MAIN CONTENT -->
        <VBox layoutX="220.0" prefHeight="600.0" prefWidth="680.0" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="220.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <VBox>
                            <children>
                                <Text fill="#ff8c00" strokeType="OUTSIDE" strokeWidth="0.0" text="> PARKING_STATUS_MONITOR">
                                    <font><Font name="Monospaced Bold" size="24.0" /></font>
                                </Text>
                                <Text fill="#ff8c00" opacity="0.6" strokeType="OUTSIDE" strokeWidth="0.0" text="REAL-TIME SENSOR FEED ACTIVE..." />
                            </children>
                        </VBox>
                        <!-- Rotating Fan in Dashboard -->
                        <StackPane fx:id="miniFan" prefHeight="50.0" prefWidth="50.0">
                            <children>
                                <Rectangle fill="#ff8c0022" height="40.0" stroke="#ff8c00" width="5.0" />
                                <Rectangle fill="#ff8c0022" height="5.0" stroke="#ff8c00" width="40.0" />
                            </children>
                        </StackPane>
                    </children>
                </HBox>

                <!-- Legend -->
                <HBox spacing="20.0">
                    <children>
                        <Label style="-fx-text-fill: #ff8c00; -fx-font-family: 'Monospaced';" text="[■] AVAILABLE" />
                        <Label style="-fx-text-fill: #442200; -fx-font-family: 'Monospaced';" text="[X] OCCUPIED" />
                    </children>
                </HBox>

                <!-- Parking Grid -->
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: #ff8c00;">
                    <content>
                        <FlowPane fx:id="parkingGrid" hgap="15.0" vgap="15.0" style="-fx-background-color: black; -fx-padding: 20;" />
                    </content>
                </ScrollPane>

                <!-- Status Bar -->
                <HBox style="-fx-border-color: #ff8c00; -fx-border-width: 1 0 0 0; -fx-padding: 10 0 0 0;">
                    <children>
                        <Label fx:id="lblSystemLog" style="-fx-text-fill: #ff8c00; -fx-font-family: 'Monospaced';" text="SYSTEM READY. AWAITING INPUT..." />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
